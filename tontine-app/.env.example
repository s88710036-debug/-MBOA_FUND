# ============================================================
# CONFIGURATION DJANGO
# ============================================================
# Mode DEBUG (False en production)
DJANGO_DEBUG=True

# Clé secrète (OBLIGATOIRE en production - génère une nouvelle clé!)
DJANGO_SECRET_KEY=change-this-in-production-super-secret-key

# Hôtes autorisés (séparés par des virgules)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================
# CONFIGURATION BASE DE DONNÉES
# ============================================================
# SQLite (développement)
# DATABASE_URL=sqlite:///db.sqlite3

# PostgreSQL (production recommandé)
# DATABASE_URL=postgres://user:password@localhost:5432/tontinedb

# ============================================================
# CONFIGURATION PAIEMENT - MODE SANDBOX/DÉVELOPPEMENT
# ============================================================

# Orange Money (Sénégal, Côte d'Ivoire, etc.)
# Obtenir les clés sur: https://partner.orange.com
ORANGE_MONEY_API_KEY=your_orange_api_key_here
ORANGE_MONEY_MERCHANT_ID=your_merchant_id_here
ORANGE_MONEY_CALLBACK_URL=http://localhost:8000/payments/webhooks/orange/

# Wave (Sénégal uniquement pour l'instant)
# Obtenir les clés sur: https://developers.wave.com
WAVE_API_KEY=your_wave_api_key_here
WAVE_API_SECRET=your_wave_api_secret_here
WAVE_CALLBACK_URL=http://localhost:8000/payments/webhooks/wave/

# Stripe (Cartes bancaires)
# Obtenir les clés sur: https://dashboard.stripe.com
STRIPE_PUBLIC_KEY=pk_test_your_public_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_CALLBACK_URL=http://localhost:8000/payments/webhooks/stripe/

# ============================================================
# CONFIGURATION SMS NOTIFICATIONS
# ============================================================
# Africa's Talking (multi-opérateurs)
# Obtenir les clés sur: https://africastalking.com
AFRICAS_TALKING_API_KEY=your_africas_talking_api_key
AFRICAS_TALKING_USERNAME=sandbox

# ============================================================
# CONFIGURATION EMAIL (PRODUCTION)
# ============================================================
# Configuration email pour l'envoi de notifications
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@example.com
EMAIL_HOST_PASSWORD=your_email_password
DEFAULT_FROM_EMAIL=TontineApp <noreply@tontine.app>

# ============================================================
# CONFIGURATION S3/CDN (PRODUCTION)
# ============================================================
# Pour stocker les fichiers statiques et médias sur S3
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_STORAGE_BUCKET_NAME=tontine-app-media
# AWS_S3_REGION_NAME=eu-west-1

# ============================================================
# CONFIGURATION REDIS/CACHE (PRODUCTION)
# ============================================================
# REDIS_URL=redis://localhost:6379/0

# ============================================================
# CONFIGURATION MONITORING (PRODUCTION)
# ============================================================
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
